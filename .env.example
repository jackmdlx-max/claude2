# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: image-generation integration for the UI mockup panel.
# ST-Streamline emits a `ui_mockup_prompt` at Stage 4. If you wire up an
# image API (e.g. OpenAI Images / DALL-E), set the key here and implement
# the fetch in src/app/api/mockup/route.ts. Left empty, the app renders the
# prompt as a styled schematic spec card instead of a generated image.
# OPENAI_API_KEY=sk-...
